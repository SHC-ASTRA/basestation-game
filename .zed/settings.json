{
  "file_scan_exclusions": [
    ".git/*",
    ".gitmodules",
    ".gitattributes",

    ".envrc",
    ".direnv",
    ".directory",
    "flake.lock",

    ".vscode",

    "*.*~",
    "*.uid",
    "*.old",
    "*.godot",
    "*.config",
    "*.import",
  ],
  "lsp": {
    "roslyn": {
      "binary": {
        "path": ".dev-bin/roslyn-ls",
        "arguments": ["--stdio", "--autoLoadProjects"],
      },
    },
  },
}
