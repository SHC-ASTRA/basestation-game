<Project Sdk="Godot.NET.Sdk/4.5.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <DefineConstants>ROS2</DefineConstants>
    <RootNamespace>basestationgame</RootNamespace>
    <NoWarn>NU1900;NU1101</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.json" Version="13.0.4" />
    <PackageReference Include="WebSocketSharp" Version="1.0.3-rc11">
        <NoWarn>NU1701</NoWarn>
    </PackageReference>
    <PackageReference Include="Siemens.RosSharp.RosBridgeClient.ROS2" Version="2.2.0" />

    <Compile Remove="./ROS/Compiler/*" />
  </ItemGroup>
</Project>
